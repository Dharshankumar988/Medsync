# ==========================
# MedSync Environment Config
# ==========================

# 1. Database & Infrastructure
DATABASE_URL=postgresql+asyncpg://medsync_user:medsync_password@localhost:5432/medsync_db
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# 2. Authentication
JWT_SECRET_KEY=generate_a_secure_random_string_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 3. AI Services
GROQ_API_KEY=gsk_your_groq_api_key_here
AI_SERVICE_URL=http://localhost:8080
AI_SERVICE_TOKEN=optional_bearer_token
AI_TIMEOUT=30

# 4. Blockchain Services (Prompt 9)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology/
BACKEND_PRIVATE_KEY=your_server_wallet_private_key_here
DOCTOR_REGISTRY_ADDRESS=0x...
PHARMACY_REGISTRY_ADDRESS=0x...
RECORD_REGISTRY_ADDRESS=0x...
PRESCRIPTION_REGISTRY_ADDRESS=0x...
CONSENT_MANAGER_ADDRESS=0x...
AUDIT_LOGGER_ADDRESS=0x...

# 5. IPFS & Storage
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# 6. Frontend Specific
NEXT_PUBLIC_API_URL=http://localhost:8000
